<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.peonnotify.obsidian-cron</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>$HOME/.claude/hooks/peon-obsidian-cron.sh</string>
  </array>
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>9</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>
  <key>StandardOutPath</key>
  <string>$HOME/.claude/logs/obsidian-cron.log</string>
  <key>StandardErrorPath</key>
  <string>$HOME/.claude/logs/obsidian-cron.log</string>
  <key>AbandonProcessGroup</key>
  <true/>
  <key>RunAtLoad</key>
  <false/>
</dict>
</plist>
