{
  "enabled": true,
  "volume": 0.6,
  "mute": false,
  "cooldown_ms": 1500,
  "log_level": "info",
  "log_max_lines": 5000,
  "sound_pack": "peon",
  "platform_override": null,
  "active_profile": "developer",

  "event_sounds": {
    "session_start":       ["ready_to_work.mp3"],
    "session_resume":      ["okie_dokey.mp3", "zug_zug.mp3"],
    "session_end":         ["jobs_done.mp3"],
    "prompt_submit":       ["work_work.mp3", "zug_zug.mp3", "ill_try.mp3", "be_happy_to.mp3", "okie_dokey.mp3", "something_need_doing.mp3"],
    "tool_start":          ["work_work.mp3"],
    "tool_done":           ["jobs_done.mp3"],
    "tool_write":          ["work_work.mp3"],
    "tool_bash":           [],
    "permission_prompt":   ["something_need_doing.mp3", "hmmm.mp3", "yes_what.mp3"],
    "idle_prompt":         ["hmmm.mp3"],
    "stop":                ["work_complete.mp3"],
    "subagent_stop":       ["jobs_done.mp3"],
    "compact_manual":      ["me_busy.mp3"],
    "compact_auto":        ["me_busy.mp3"],
    "error":               ["never_mind.mp3"],
    "system_error":        ["leave_me_alone.mp3"],
    "limit":               ["more_gold_required.mp3"],
    "codeguard_pass":      ["jobs_done.mp3"],
    "codeguard_lint_fail": ["never_mind.mp3"],
    "codeguard_error":     ["leave_me_alone.mp3"]
  },

  "codeguard": {
    "enabled": true,
    "lint_enabled": true,
    "validate_data_files": true,
    "claude_debug_enabled": true,
    "claude_debug_model": "sonnet",
    "blocking_mode": false,
    "max_file_size_kb": 100,
    "max_reviews_per_file": 3,
    "max_reviews_per_session": 20,
    "dedup_enabled": true,
    "review_prompt": null,
    "skip_extensions": [".md", ".txt", ".csv", ".lock", ".svg", ".png", ".jpg", ".jpeg", ".gif", ".ico", ".woff", ".woff2", ".eot", ".ttf", ".map", ".d.ts"],
    "skip_directories": ["node_modules", "vendor", "dist", "build", ".git", "__pycache__", ".next", "coverage", ".tox", ".mypy_cache", "target", ".venv", "venv"],
    "validate_extensions": [".json", ".jsonl", ".ndjson", ".yaml", ".yml", ".toml"],
    "secondary_lint_enabled": false,
    "lint_timeout_sec": 5,
    "debug_timeout_sec": 20
  },

  "docguard": {
    "enabled": true,
    "update_changelog": true,
    "update_claude_md": true,
    "suggest_readme": false,
    "sync_memory_md": true,
    "min_score_threshold": 3,
    "flush_model": "sonnet",
    "flush_timeout_sec": 45,
    "memory_dir": ""
  },

  "event_cooldowns": {
    "tool_start": 5000,
    "tool_done": 5000,
    "tool_bash": 10000,
    "prompt_submit": 0,
    "stop": 0,
    "permission_prompt": 0,
    "session_start": 0
  },

  "watchdog": {
    "enabled": true,
    "warn_mb": 800,
    "kill_mb": 1200,
    "warn_sound": "me_not_that_kind_of_orc.mp3",
    "kill_sound": "peon_death.mp3",
    "warn_cooldown_sec": 300,
    "auto_restart": true
  },

  "obsidian": {
    "enabled": true,
    "vault_path": "~/Documents/Obsidian",
    "flush_model": "sonnet",
    "flush_timeout_sec": 60,
    "flush_mode": "hybrid",
    "create_atomic_notes": true,
    "daily_notes": true,
    "project_tracking": true,
    "goal_tracking": true,
    "max_atomic_notes_per_session": 5,
    "max_prompt_tokens": 30000,
    "min_score_threshold": 5,
    "max_retries": 2,
    "retry_delay_sec": 3,
    "auto_archive": true,
    "archive_after_days": 90,
    "cron_enabled": true,
    "cron_hour": 9,
    "cron_gap_days": 7,
    "cron_trend_days": 7
  },

  "profiles": {
    "developer": {
      "event_sounds": {
        "permission_prompt": ["something_need_doing.mp3"],
        "stop": ["work_complete.mp3"],
        "subagent_stop": ["jobs_done.mp3"]
      },
      "codeguard": { "enabled": false },
      "docguard": { "enabled": false },
      "obsidian": { "enabled": false }
    }
  }
}
